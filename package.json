{
  "name": "whatsapp-bot",
  "version": "1.0.0",
  "description": "Client-hosted WhatsApp automation bot",
  "main": "server.js",
  "bin": "server.js",
  "type": "commonjs",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "build": "pkg . --targets node18-win-x64 --output WhatsAppBot"
  },
  "engines": {
    "node": "18.x"
  },
  "pkg": {
    "assets": [
      "public/**/*",
      ".env",
      "node_modules/whatsapp-web.js/**/*"
    ],
    "scripts": [
      "server.js"
    ]
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "mongodb": "^5.9.2",
    "mongoose": "^7.8.9",
    "open": "^10.2.0",
    "puppeteer": "^24.40.0",
    "qrcode": "^1.5.4",
    "qrcode-terminal": "^0.12.0",
    "whatsapp-web.js": "^1.34.6"
  },
  "devDependencies": {
    "nodemon": "^3.1.14"
  }
}
